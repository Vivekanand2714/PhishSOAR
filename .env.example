# ============================================================
# SOAR Playbook - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# VirusTotal API Key (free at https://virustotal.com)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLScan.io API Key (free at https://urlscan.io)
URLSCAN_API_KEY=your_urlscan_api_key_here

# Slack Webhook URL (optional - for notifications)
SLACK_WEBHOOK_URL=

# Gmail label to monitor (default: INBOX)
GMAIL_LABEL=INBOX

# Phishing label to apply on quarantine
QUARANTINE_LABEL=SOAR-Quarantined

# Flask server port
FLASK_PORT=5000
